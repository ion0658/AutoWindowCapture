<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ConfigPage.Views.ConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ConfigPage.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:page="using:ConfigPage"
      xmlns:config="using:ConfigManager.Models"
      mc:Ignorable="d">

    <Page.Resources>
        <page:BoolToEnumConverter x:Key="Enum" />
    </Page.Resources>

    <ScrollViewer>

        <StackPanel Spacing="12"
                    Padding="0,12,0,0">
            <TextBlock Text="設定"
                       FontSize="24"
                       FontWeight="SemiBold" />

            <TextBlock Text="録画フォーマット" />

            <TextBlock Text="コーデック" />
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
                <RadioButton Content="H.264"
                             GroupName="RecordingCodec"
                             IsChecked="{x:Bind vm.SelectedRecordingCodec, Converter={StaticResource Enum}, ConverterParameter=H264, Mode=TwoWay}" />
                <RadioButton Content="HEVC"
                             GroupName="RecordingCodec"
                             IsChecked="{x:Bind vm.SelectedRecordingCodec, Converter={StaticResource Enum}, ConverterParameter=HEVC, Mode=TwoWay}" />
            </StackPanel>

            <TextBlock Text="解像度" />
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
                <RadioButton Content="Source"
                             GroupName="RecordingResolution"
                             IsChecked="{x:Bind vm.SelectedRecordingResolution, Converter={StaticResource Enum}, ConverterParameter=Source, Mode=TwoWay}" />
                <RadioButton Content="1280 x 720"
                             GroupName="RecordingResolution"
                             IsChecked="{x:Bind vm.SelectedRecordingResolution, Converter={StaticResource Enum}, ConverterParameter=HD_1280x720, Mode=TwoWay}" />
                <RadioButton Content="1920 x 1080"
                             GroupName="RecordingResolution"
                             IsChecked="{x:Bind vm.SelectedRecordingResolution, Converter={StaticResource Enum}, ConverterParameter=FHD_1920x1080, Mode=TwoWay}" />
                <RadioButton Content="3840 x 2160"
                             GroupName="RecordingResolution"
                             IsChecked="{x:Bind vm.SelectedRecordingResolution, Converter={StaticResource Enum}, ConverterParameter=UHD_3840x2160, Mode=TwoWay}" />
            </StackPanel>

            <TextBlock Text="録画データ保存先" />
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <TextBox Width="520"
                         IsReadOnly="True"
                         Text="{x:Bind vm.RecordingSaveDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="フォルダーを選択"
                        Click="SelectRecordingDirectory_Click" />
            </StackPanel>

            <TextBlock Text="自動録画を開始する実行ファイル" />
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button Content="実行ファイルを追加"
                        Click="AddExecutableFiles_Click" />
                <Button Content="選択項目を削除"
                        Command="{x:Bind vm.RemoveSelectedExecutableCommand}" />
            </StackPanel>

            <ListView Height="180"
                      ItemsSource="{x:Bind vm.AutoRecordingExecutableNames, Mode=OneWay}"
                      SelectedItem="{x:Bind vm.SelectedExecutableName, Mode=TwoWay}" />

        </StackPanel>
    </ScrollViewer>
</Page>

