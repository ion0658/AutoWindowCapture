<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AutoWindowCapture.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:AutoWindowCapture"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windowlist="using:WindowListPage.Views"
        xmlns:config="using:ConfigPage.Views"
        mc:Ignorable="d"
        Title="AutoWindowCapture">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView PaneDisplayMode="LeftMinimal"
                    IsBackButtonVisible="Collapsed"
                    SelectedItem="{x:Bind vm.SelectedItem, Mode=TwoWay}">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="ウィンドウ一覧"
                                Icon="AllApps"
                                IsSelected="True"
                                Tag="WindowList" />
        </NavigationView.MenuItems>
        <Frame x:Name="ContentFrame"
               Padding="50" />
    </NavigationView>
</Window>
